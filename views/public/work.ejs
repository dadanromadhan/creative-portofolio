<section class="section max-w-[1400px] mx-auto px-6 sm:px-8">
  <div class="section__header reveal-up">
    <div class="section__label"><%= t('work.title') %></div>
    <h1 class="section__title font-display"><%= t('work.title') %></h1>
    <div class="section__divider"></div>
  </div>

  <div class="filter-bar reveal-up" id="filters">
    <button data-cat="all" class="filter-btn active"><%= t('work.filter.all') %></button>
    <% categories.forEach(c => { %>
      <button data-cat="<%= c.id %>" class="filter-btn"><%= c.icon %> <%= c.label %></button>
    <% }) %>
  </div>

  <div id="grid" class="portfolio-grid stagger-children">
    <% if (!media.length) { %>
      <p class="col-span-full text-center text-gray-500 py-20"><%= t('work.empty') %></p>
    <% } %>
    <% media.forEach((m, i) => { %>
      <article id="item-<%= m.id %>" class="portfolio-card media-item reveal-scale"
               data-cat="<%= m.category?.id || '' %>">
        <span class="portfolio-card__index"><%= String(i + 1).padStart(2, '0') %></span>

        <% if (m.embedCode) { %>
          <div class="embed-code-container">
            <%- m.embedCode %>
          </div>
        <% } else if (m.type === 'embed' || (m.source && m.source.match(/instagram\.com\/p\//))) { %>
          <div class="relative" style="aspect-ratio: 16/9;">
            <iframe src="<%= m.source.replace(/\/+$/, '') %>/embed/" loading="lazy" allowfullscreen title="<%= m.title %>"></iframe>
          </div>
        <% } else if (m.type === 'image' && m.source) { %>
          <div class="portfolio-card__image-wrap" style="aspect-ratio: 16/9;">
            <img src="<%= m.source %>" loading="lazy" alt="<%= m.title %>" />
          </div>
        <% } else if (m.type === 'video' && m.source) { %>
          <div class="portfolio-card__image-wrap" style="aspect-ratio: 16/9;">
            <video src="<%= m.source %>" muted loop playsinline
                   onmouseover="this.play()" onmouseout="this.pause();this.currentTime=0;"></video>
            <div class="portfolio-card__play">&#9654;</div>
          </div>
        <% } else { %>
          <div class="relative" style="aspect-ratio: 16/9;">
            <img src="<%= m.source %>" loading="lazy" style="width:100%;height:100%;object-fit:cover" alt="<%= m.title %>" />
            <% if (m.type === 'video') { %>
            <div class="portfolio-card__play">&#9654;</div>
            <% } %>
          </div>
        <% } %>

        <div class="portfolio-card__overlay"></div>
        <div class="portfolio-card__info">
          <p class="portfolio-card__title"><%= m.title %></p>
          <% if (m.category) { %>
            <p class="portfolio-card__cat"><%= m.category.label %></p>
          <% } %>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<div id="lightbox" class="lightbox">
  <button id="lbClose" class="lightbox__close">&times;</button>
  <div id="lbContent" class="lightbox__content"></div>
</div>
