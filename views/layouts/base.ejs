<!DOCTYPE html>
<html lang="<%= lang %>" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#050505" />
    <meta name="color-scheme" content="dark" />
    <title><%= title %> | Dadan R.</title>
    <link rel="manifest" href="/manifest.json" />
    <meta name="description" content="Portfolio of Dadan Romadhan — videographer, photographer, editor" />

    <script>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              ink: "#050505",
              charcoal: "#0c0c0c",
              smoke: "#151515",
              ash: "#222",
              silver: "#707070",
              gold: "#c9a84c",
              "gold-dim": "#a08530",
              "gold-light": "#e2cc7e",
              cream: "#f5eedf",
            },
            fontFamily: {
              display: ['"Playfair Display"', "Georgia", "serif"],
              sans: ["Inter", "system-ui", "sans-serif"],
            },
          },
        },
      };
    </script>
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@400;500;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body class="bg-ink text-gray-100 font-sans antialiased selection:bg-gold/30 selection:text-white">
    <div class="page-loader" id="pageLoader">
      <div class="page-loader__inner">
        <div class="page-loader__bar"></div>
        <div class="page-loader__text"><span>D</span><span>a</span><span>d</span><span>a</span><span>n</span><span>&nbsp;R</span><span>.</span></div>
      </div>
    </div>

    <div class="noise-overlay"></div>

    <div class="page-transition" id="pageTransition">
      <div class="page-transition__curtain"></div>
      <div class="page-transition__curtain"></div>
      <div class="page-transition__curtain"></div>
    </div>

    <%- include('../partials/nav') %>
    <main><%- body %></main>
    <%- include('../partials/footer') %>

    <script src="/js/main.js" defer></script>
    <script src="/sw-register.js" defer></script>
  </body>
</html>
